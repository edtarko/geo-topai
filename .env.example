# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="your_gemini_api_key_here"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="http://localhost:3000"

# GITHUB_TOKEN: Optional. Used to fetch accurate star counts and project metadata.
# Generate one at https://github.com/settings/tokens
GITHUB_TOKEN="your_github_token_here"

# GITHUB_TOKEN_BACKUP: Optional backup token for manual failover.
GITHUB_TOKEN_BACKUP="your_github_backup_token_here"

# Multi-account token pool (recommended for high-volume sync):
# 1) Add extra named env vars:
GITHUB_TOKEN_2="your_second_github_token_here"
GITHUB_TOKEN_3="your_third_github_token_here"
# 2) Or provide a comma/newline-separated list:
GITHUB_TOKENS="token_a,token_b,token_c"

# OPENALEX_MAILTO: Optional, improves OpenAlex API reliability/rate behavior.
OPENALEX_MAILTO="your-email@example.com"

# GEO Space export/publish settings (optional):
GEO_SPACE_PAYLOAD_DIR="geo_space_payload"
GEO_SPACE_ID=""
GEO_NETWORK="testnet"
GEO_GRAPH_URI="TESTNET"
GEO_PRIVATE_KEY="f2f3b16dc54540b505917dbf726f9a625b5844ec0457179c16839e80f870857d"
GEO_SPACE_REGISTRY="0xB01683b2f0d38d43fcD4D9aAB980166988924132"
GEO_PERSON_CSV_PATH="Person.csv"
GEO_PAPER_CSV_PATH="Paper.csv"
GEO_PROJECTS_CSV_PATH="Projects.csv"
